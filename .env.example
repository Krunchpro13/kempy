# =============================================================================
# KEMPY Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in what you have. EVERY setting is optional
# — the server runs in degraded modes when keys are missing, so you can add
# infrastructure incrementally without ever editing code.

# -----------------------------------------------------------------------------
# eBay Browse API (FREE)
# -----------------------------------------------------------------------------
# https://developer.ebay.com → My Account → Application Keys → Production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Keepa Amazon API (~$20/mo)
# -----------------------------------------------------------------------------
# https://keepa.com → Data subscription → https://keepa.com/#!api
KEEPA_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic Claude API (pay-as-you-go, ~$0.001 per match)
# -----------------------------------------------------------------------------
# https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Redis cache (recommended once Claude/Keepa are live)
# -----------------------------------------------------------------------------
# Caches at 3 layers: full search (10 min), Keepa candidates (6h), Claude
# decisions (7 days). Without this, every search burns API tokens.
#
# Local dev:        redis://localhost:6379
# Docker:           docker run -d -p 6379:6379 redis:7-alpine
# Managed (free):   https://upstash.com (Upstash gives serverless Redis)
REDIS_URL=

# -----------------------------------------------------------------------------
# Postgres database (needed for the watchlist feature)
# -----------------------------------------------------------------------------
# After setting this, run:  npm run migrate
#
# Local dev:    postgresql://user:pass@localhost:5432/kempy
# Docker:       docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=kempy -e POSTGRES_DB=kempy postgres:16
# Managed:      https://neon.tech (free tier), https://supabase.com (free tier)
DATABASE_URL=

# -----------------------------------------------------------------------------
# JWT secret (REQUIRED in production)
# -----------------------------------------------------------------------------
# 32+ character random string for signing session tokens. In development one is
# auto-generated per boot (sessions reset on restart). In production this MUST
# be set or auth will not work.
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# -----------------------------------------------------------------------------
# Server config
# -----------------------------------------------------------------------------
PORT=3000

EBAY_MARKETPLACE=EBAY_US
KEEPA_DOMAIN=1
# Keepa domains: 1=US 2=UK 3=DE 4=FR 5=JP 6=CA 8=IT 9=ES 10=IN 11=MX
